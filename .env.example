# Plywood Market Intelligence Pipeline - API Keys
# Copy this file to .env and fill in your keys

# EIA API - Brent Crude oil price (free: https://www.eia.gov/opendata/register.php)
EIA_API_KEY=your_eia_api_key_here

# FRED API - FX rates (free: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Open Exchange Rates - Additional FX rates (free: https://openexchangerates.org/signup/free)
OXR_APP_ID=your_oxr_app_id_here
